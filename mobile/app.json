{
  "expo": {
    "name": "Sistema POS Mobile",
    "slug": "sistema-pos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e293b"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e293b"
      },
      "package": "com.sistemapos.mobile"
    },
    "ios": {
      "bundleIdentifier": "com.sistemapos.mobile"
    },
    "plugins": ["expo-router"],
    "scheme": "sistema-pos"
  }
}
